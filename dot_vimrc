call plug#begin()

Plug 'sheerun/vim-polyglot'
Plug 'catppuccin/vim', { 'as': 'catppuccin' }
Plug 'jszakmeister/vim-togglecursor'
Plug 'tribela/vim-transparent'

call plug#end()

set termguicolors
set tabstop=2
set shiftwidth=2
set smartindent
set expandtab
set number
set clipboard=unnamed
set incsearch
set hlsearch
set ignorecase
set smartcase
set mouse=a
set scrolloff=5

colorscheme desert

let mapleader=" "

inoremap kj <Esc>

nnoremap <silent> <leader>h :nohlsearch<CR>
