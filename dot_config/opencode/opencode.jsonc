{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:API_KEY_MCP_CONTEXT7}",
      },
    },
    "chrome": {
      "type": "local",
      "command": ["bunx", "chrome-devtools-mcp@latest"],
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:API_KEY_MCP_EXA}",
    }
  },
}
