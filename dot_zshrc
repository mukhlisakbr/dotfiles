# ohmyzsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
zstyle ':omz:plugins:eza' 'icons' yes
zstyle ':omz:plugins:eza' 'dirs-first' yes
plugins=(
	brew
	composer
	eza
	fzf
	git
	laravel
	npm
	ssh
	sublime
	uv
	zoxide
  starship
)
source "$ZSH/oh-my-zsh.sh"

# zinit
source /opt/homebrew/opt/zinit/zinit.zsh
zinit light zsh-users/zsh-autosuggestions
zinit light zsh-users/zsh-syntax-highlighting

# homebrew
export HOMEBREW_NO_ENV_HINTS=1

# editor
export EDITOR='vim'

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# git
alias wip='git add . && git commit -m "wip" && git push'

# claudecode
alias cc="claude --dangerously-skip-permissions"

# opencode
alias oc="OPENCODE_ENABLE_EXA=1 opencode"

# uv
export PATH="/Users/ghost/.local/bin:$PATH"

# java
export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home

# android
export ANDROID_HOME="$HOME/Library/Android/sdk"
export PATH="$PATH:$ANDROID_HOME/emulator"
export PATH="$PATH:$ANDROID_HOME/platform-tools"

# bitwarden ssh agent
export SSH_AUTH_SOCK=/Users/ghost/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock

# herd
export PATH="/Users/ghost/Library/Application Support/Herd/bin/":$PATH
export HERD_PHP_84_INI_SCAN_DIR="/Users/ghost/Library/Application Support/Herd/config/php/84/"
export HERD_PHP_85_INI_SCAN_DIR="/Users/ghost/Library/Application Support/Herd/config/php/85/"

# yazi
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}
